# =========================================================================
# Cantonese Language Learning Platform - Environment Configuration Template
# =========================================================================

# Database URL (Used by FastAPI and Celery. Internal Docker address is db:5432)
DATABASE_URL=postgresql://admin:development_password_secure@db:5432/cantonese_app

# Redis URL (Used by Celery broker. Internal Docker address is redis:6379)
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------------------
# Option A: GCP Vertex AI Configuration (Recommended)
# -------------------------------------------------------------------------
# Google Cloud Project ID
GCP_PROJECT=your-gcp-project-id

# Google Cloud Region (e.g. us-central1, europe-west1)
GCP_LOCATION=us-central1

# Path to the Google Cloud Service Account JSON credential file.
# Note: If you place your JSON file in the "server/" directory (e.g., named "vertex_credentials.json"),
# it is mounted automatically to "/code/vertex_credentials.json" inside the container.
GOOGLE_APPLICATION_CREDENTIALS=/code/vertex_credentials.json

# -------------------------------------------------------------------------
# Option B: Standard Developer API Key Fallback
# -------------------------------------------------------------------------
# Optional fallback if you are not using Vertex AI
GEMINI_API_KEY=
